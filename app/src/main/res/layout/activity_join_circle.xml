<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/new_manto_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Manto"
            android:textColor="@color/manto_green"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_role_setup_chip"
            android:paddingStart="14dp"
            android:paddingTop="6dp"
            android:paddingEnd="14dp"
            android:paddingBottom="6dp"
            android:text="CONFIGURACIÓN DEL DISPOSITIVO"
            android:textAllCaps="true"
            android:textColor="#7B9692"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="Unirse al Círculo"
            android:textColor="#111315"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Ingresa el código que te envió tu Administrador para conectarte con tu familia"
            android:textColor="#3E464A"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_host_setup_panel"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Código de invitación"
                android:textColor="#1D2428"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etJoinInvitationCode"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_host_setup_input"
                android:gravity="center"
                android:hint="M4nt0W15K"
                android:inputType="text"
                android:letterSpacing="0.18"
                android:maxLength="8"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textAllCaps="true"
                android:textColor="#121416"
                android:textColorHint="#8B9498"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnValidateJoinCode"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_host_setup_light_button"
                android:text="Validar Código"
                android:textAllCaps="false"
                android:textColor="#10181C"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_host_setup_panel"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Código personal"
                android:textColor="#1D2428"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPersonalCodeValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="M4nt0-W15K"
                android:textColor="@color/manto_green"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvNoCodeHelp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:text="¿No recibí ningún código?"
            android:textColor="@color/manto_green"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackJoinFlow"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_host_setup_light_button"
            android:text="Retroceder"
            android:textAllCaps="false"
            android:textColor="#1D2428"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Paso 2 de 2 - Configurando tu seguridad"
            android:textColor="#8A8D8F"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
