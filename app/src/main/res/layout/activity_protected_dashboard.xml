<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/manto_background"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estás protegido"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvHostName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tu familiar está cuidando de ti"
        android:textSize="16sp"
        android:textColor="@color/manto_gray_text"
        android:textAlignment="center"
        android:layout_marginBottom="48dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSos"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:text="SOS"
        android:textSize="48sp"
        android:textStyle="bold"
        app:cornerRadius="100dp"
        android:backgroundTint="@android:color/holo_red_dark"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnCallHost"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Llamar a mi familiar"
        android:textSize="18sp"
        app:icon="@android:drawable/ic_menu_call"
        android:backgroundTint="@color/manto_green"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnSimulateThreat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DEMO: Simular SMS Sospechoso"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="@android:color/holo_orange_dark"
        app:strokeColor="@android:color/holo_orange_dark"
        android:layout_marginBottom="32dp"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <TextView
        android:id="@+id/tvLogoutProtected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cerrar Sesión"
        android:textColor="@android:color/holo_red_dark"
        android:padding="16dp"
        android:textStyle="bold"/>

</LinearLayout>