<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/manto_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estás protegido"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvHostName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tu familiar está cuidando de ti"
        android:textSize="16sp"
        android:textColor="@color/manto_gray_text"
        android:textAlignment="center"
        android:layout_marginBottom="48dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSos"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:text="SOS"
        android:textSize="48sp"
        android:textStyle="bold"
        app:cornerRadius="100dp"
        android:backgroundTint="@android:color/holo_red_dark"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnCallHost"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Llamar a mi familiar"
        android:textSize="18sp"
        app:icon="@android:drawable/ic_menu_call"
        android:backgroundTint="@color/manto_green"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:id="@+id/layoutVerificationCodeInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E8F5E9"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Código de verificación familiar"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#1B5E20"/>

        <TextView
            android:id="@+id/tvVerificationCodePersistent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="------"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp"
            android:textColor="#2E7D32"/>

        <TextView
            android:id="@+id/tvVerificationCodeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Esperando respuesta de tu familiar"
            android:textSize="13sp"
            android:textColor="#33691E"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnSimulateThreat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DEMO: Simular SMS Sospechoso"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="@android:color/holo_orange_dark"
        app:strokeColor="@android:color/holo_orange_dark"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnOpenSecurityMirrorProtected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Abrir Espejo de Seguridad"
        android:backgroundTint="@color/manto_green"
        android:textColor="@android:color/white"
        android:layout_marginBottom="24dp"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <TextView
            android:id="@+id/tvLogoutProtected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cerrar Sesión"
            android:textColor="@android:color/holo_red_dark"
            android:padding="16dp"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>
