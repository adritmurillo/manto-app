<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8F7"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nuevo mensaje"
        android:textColor="#101216"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Destinatario"
        android:textColor="#4C565C"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvComposeRecipient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_link_shield_input"
        android:padding="14dp"
        android:text="Sin destinatario"
        android:textColor="#101216"
        android:textSize="16sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Mensaje"
        android:textColor="#4C565C"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/etComposeMessage"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_security_surface"
        android:gravity="top|start"
        android:hint="Escribe tu mensaje"
        android:inputType="textMultiLine"
        android:padding="14dp"
        android:textColor="#101216"
        android:textColorHint="#94A1A0" />

    <Button
        android:id="@+id/btnComposeSend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/manto_green"
        android:text="Enviar"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/btnComposeClose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Cerrar" />

</LinearLayout>
