<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F6F6"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Modulo de mensajeria en construccion"
        android:textColor="#111111"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvComposeRecipient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Destino detectado"
        android:textColor="#4C565C"
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="La lectura y analisis real de SMS ya esta activa. El envio y la bandeja completa se completan en el siguiente modulo."
        android:textColor="#4C565C"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnComposeClose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:backgroundTint="#4FBBB2"
        android:text="Cerrar"
        android:textColor="@android:color/white" />
</LinearLayout>
