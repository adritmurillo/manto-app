<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_security_surface"
    android:orientation="horizontal"
    android:padding="12dp">

    <View
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_chip_danger" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvShieldUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="bit.ly.ws/secure-logini-211"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvShieldStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_danger"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:text="PHISHING"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvShieldMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="12 May 2026, 09:15"
                android:textColor="#717171"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnShieldAction"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="Desbloquear"
        android:textSize="11sp" />
</LinearLayout>
