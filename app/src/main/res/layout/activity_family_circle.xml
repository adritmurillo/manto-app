<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/manto_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Circulo Familiar"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Grupo"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFamilyNameValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="-"
        android:paddingBottom="10dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Miembros"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFamilyMembersValue"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="-"
        android:padding="10dp"
        android:background="#EDEDED"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnInviteSecondaryHost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Generar token host ayudante"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvSecondaryInviteCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Token ayudante: ---"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnInviteProtected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Generar token protegido"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvProtectedInviteCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Token protegido: ---"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnRefreshFamily"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Actualizar" />

</LinearLayout>
