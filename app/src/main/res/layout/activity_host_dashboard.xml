<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Panel de Control"
    android:textSize="28sp"
    android:textStyle="bold"
    android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Monitoreando a tus familiares"
        android:textColor="#757575"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:tint="#4CAF50"
                    android:layout_marginEnd="16dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvProtectedName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protegiendo a: Mi Hermano"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvProtectedStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estado: Vigilancia Activa"
                        android:textColor="#4CAF50"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Últimas Alertas"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:id="@+id/layoutEmergencyBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFF8E1"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvEmergencyBannerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Emergencia activa"
            android:textColor="#6D4C41"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnOpenEmergencyBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Abrir emergencia"
            android:backgroundTint="#F57C00"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnMuteEmergencyAudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Silenciar audio en vivo"
            android:backgroundTint="#546E7A"
            android:textColor="@android:color/white"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvAlertsLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="• Hace 2 hrs: Intento de acceso a 'actualizar-datos.com' (BLOQUEADO)\n\n• Ayer: Conexión segura establecida"
        android:textColor="#616161"
        android:background="#E0E0E0"
        android:padding="16dp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Historial de emergencias"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvEmergencyHistoryEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sin emergencias recientes"
        android:textColor="#616161"
        android:background="#E3F2FD"
        android:padding="16dp"
        android:layout_marginBottom="12dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEmergencyHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnRefreshStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Actualizar Estado"
        android:backgroundTint="#4CAF50"/>

    <Button
        android:id="@+id/btnOpenLinkShieldDashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver Escudo de Enlaces"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/manto_green"/>

    <Button
        android:id="@+id/btnOpenSecurityMirrorDashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver Espejo de Seguridad"
        android:layout_marginTop="10dp"
        android:backgroundTint="#2F8473"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <TextView
            android:id="@+id/tvLogoutHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cerrar Sesión"
            android:textColor="@android:color/holo_red_dark"
            android:textAlignment="center"
            android:padding="16dp"
            android:textStyle="bold"/>
    </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavHost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:itemIconTint="@color/manto_green"
        app:itemTextColor="@color/manto_green"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_host_bottom_nav" />
</LinearLayout>
