<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_security_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reciente"
        android:textColor="#7F8A8F"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvProtectedSmsSender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+21 973749157"
            android:textColor="#111417"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProtectedSmsTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_neutral"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="RECIBIDO"
            android:textColor="#385B58"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_link_shield_input"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contenido del mensaje"
            android:textColor="#687678"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvProtectedSmsMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Mensaje recibido"
            android:textColor="#202628"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvProtectedSmsUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="https://ejemplo.com"
            android:textColor="#D45A53"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvProtectedSmsState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Bloqueado por seguridad"
        android:textColor="#101216"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvProtectedSmsReceived"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Recibido hoy, 14:22 PM"
        android:textColor="#6D777C"
        android:textSize="12sp" />

</LinearLayout>
